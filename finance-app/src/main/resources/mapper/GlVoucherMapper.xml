<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.finance.module.ledger.mapper.GlVoucherMapper">

    <select id="selectListWithEntries" resultMap="voucherMap">
        SELECT v.*, e.id e_id, e.line_no AS entry_no, e.aux_summary e_summary, e.subject_code, e.subject_name,
               e.aux_customer_id, e.aux_supplier_id, e.aux_dept_id, e.aux_project_id,
               e.aux_employee_id AS aux_person_id, e.aux_product_id AS aux_goods_id,
               e.currency_code, e.exchange_rate, e.orig_amount AS original_amount,
               CASE WHEN e.dc_direction = 'DEBIT' THEN e.amount ELSE 0 END AS debit_amount,
               CASE WHEN e.dc_direction = 'CREDIT' THEN e.amount ELSE 0 END AS credit_amount,
               e.quantity, e.price AS price_unit
        FROM gl_voucher v
        LEFT JOIN gl_voucher_entry e ON v.id = e.voucher_id
        <if test="ew != null and ew.sqlSegment != null and ew.sqlSegment != ''">
            ${ew.sqlSegment}
        </if>
        ORDER BY v.voucher_date DESC, v.id DESC, e.line_no ASC
    </select>

    <resultMap id="voucherMap" type="com.finance.module.ledger.entity.GlVoucher">
        <id property="id" column="id"/>
        <result property="voucherNo" column="voucher_no"/>
        <result property="voucherType" column="voucher_type"/>
        <result property="voucherWord" column="voucher_word"/>
        <result property="voucherSeq" column="voucher_seq"/>
        <result property="voucherDate" column="voucher_date"/>
        <result property="fiscalYear" column="fiscal_year"/>
        <result property="fiscalPeriod" column="fiscal_period"/>
        <result property="summary" column="summary"/>
        <result property="totalDebit" column="total_debit"/>
        <result property="totalCredit" column="total_credit"/>
        <result property="status" column="status"/>
        <result property="sourceModule" column="source_module"/>
        <result property="sourceBillId" column="source_bill_id"/>
        <result property="attachmentIds" column="attachment_ids"/>
        <result property="creator" column="creator"/>
        <result property="creatorName" column="creator_name"/>
        <result property="createTime" column="create_time"/>
        <result property="auditor" column="auditor"/>
        <result property="auditorName" column="auditor_name"/>
        <result property="auditTime" column="audit_time"/>
        <result property="poster" column="poster"/>
        <result property="posterName" column="poster_name"/>
        <result property="postTime" column="post_time"/>
        <result property="remark" column="remark"/>
        <collection property="entries" ofType="com.finance.module.ledger.entity.GlVoucherEntry">
            <id property="id" column="e_id"/>
            <result property="entryNo" column="entry_no"/>
            <result property="summary" column="e_summary"/>
            <result property="subjectCode" column="subject_code"/>
            <result property="subjectName" column="subject_name"/>
            <result property="auxCustomerId" column="aux_customer_id"/>
            <result property="auxCustomerName" column="aux_customer_name"/>
            <result property="auxSupplierId" column="aux_supplier_id"/>
            <result property="auxSupplierName" column="aux_supplier_name"/>
            <result property="auxDeptId" column="aux_dept_id"/>
            <result property="auxDeptName" column="aux_dept_name"/>
            <result property="auxProjectId" column="aux_project_id"/>
            <result property="auxProjectName" column="aux_project_name"/>
            <result property="auxPersonId" column="aux_person_id"/>
            <result property="auxPersonName" column="aux_person_name"/>
            <result property="auxGoodsId" column="aux_goods_id"/>
            <result property="auxGoodsName" column="aux_goods_name"/>
            <result property="currencyCode" column="currency_code"/>
            <result property="exchangeRate" column="exchange_rate"/>
            <result property="originalAmount" column="original_amount"/>
            <result property="debitAmount" column="debit_amount"/>
            <result property="creditAmount" column="credit_amount"/>
            <result property="quantity" column="quantity"/>
            <result property="priceUnit" column="price_unit"/>
            <result property="billNo" column="bill_no"/>
        </collection>
    </resultMap>

</mapper>
